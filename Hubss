-- [[ IMPROVED TP DOWN ACTION (WITH FLOAT HANDLING) ]] --
local floatDisabledTemp = false

local function tpDownAction()
    local char = LocalPlayer.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Store float state and disable it completely for a while
    local wasFloatEnabled = SETTINGS.FLOAT_ENABLED
    if wasFloatEnabled then
        floatDisabledTemp = true
        if floatBodyPosition then
            floatBodyPosition:Destroy()
            floatBodyPosition = nil
        end
    end

    -- Perform teleport
    local rayOrigin = rootPart.Position
    local rayDirection = Vector3.new(0, -500, 0)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

    local result = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    if result then
        local groundPos = result.Position + Vector3.new(0, 3, 0)
        rootPart.CFrame = CFrame.new(groundPos)
        rootPart.Velocity = Vector3.zero
        rootPart.RotVelocity = Vector3.zero
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum:ChangeState(Enum.HumanoidStateType.Landed)
        end
    else
        warn("No ground found below")
    end

    -- Wait for the character to settle, then re‑enable float if it was on
    if wasFloatEnabled then
        task.wait(0.5)  -- Longer delay to ensure the character stays grounded
        floatDisabledTemp = false
        -- updateFloat will recreate the BodyPosition next heartbeat
    end
end

