-- Optimized loop - runs 10x per second instead of 60
task.spawn(function()
    while task.wait(0.1) do
        if not SETTINGS.ENABLED then continue end
        if isStealing then continue end
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local hrpPos = hrp.Position
        local nearestPrompt = nil
        local minDist = SETTINGS.RADIUS
        for _, prompt in ipairs(promptsCache) do
            if prompt and prompt.Parent and prompt.Enabled then
                local pos = getPromptPos(prompt)
                if pos then
                    local dist = (hrpPos - pos).Magnitude
                    if dist <= minDist then
                        minDist = dist
                        nearestPrompt = prompt
                    end
                end
            end
        end
        if nearestPrompt then startStealLoop(nearestPrompt) end
    end
end)

