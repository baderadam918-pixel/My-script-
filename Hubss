        extrasPage.CanvasSize = UDim2.new(0, 0, 0, extrasContainer.AbsoluteSize.Y + 10 * scale)
    end

    mainContainer.ChildAdded:Connect(updatePageSizes)
    extrasContainer.ChildAdded:Connect(updatePageSizes)
    task.wait(0.1)
    updatePageSizes()
