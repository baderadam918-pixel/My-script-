-- [[ KEYBINDS ]] --
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    local key = input.KeyCode
    if key == Enum.KeyCode.Unknown then return end
    local keyName = key.Name
    if KEYBINDS.LOCK == keyName then
        setMeleeEnabled(not meleeEnabled)
        if mainGUI then refreshMainGUI() end
    elseif KEYBINDS.DROP == keyName then
        momentaryDropFling()
    elseif KEYBINDS.AUTOLEFT == keyName then
        SETTINGS.AUTOLEFT = not SETTINGS.AUTOLEFT
        if SETTINGS.AUTOLEFT then SETTINGS.AUTORIGHT = false; RightPhase = 1; if setAutoRightState then setAutoRightState(false) end end
        LeftPhase = 1
        if mainGUI then refreshMainGUI() end
    elseif KEYBINDS.AUTORIGHT == keyName then
        SETTINGS.AUTORIGHT = not SETTINGS.AUTORIGHT
        if SETTINGS.AUTORIGHT then SETTINGS.AUTOLEFT = false; LeftPhase = 1; if setAutoLeftState then setAutoLeftState(false) end end
        RightPhase = 1
        if mainGUI then refreshMainGUI() end
    elseif KEYBINDS.FLOAT == keyName then
        SETTINGS.FLOAT_ENABLED = not SETTINGS.FLOAT_ENABLED
        if not SETTINGS.FLOAT_ENABLED and floatBodyPosition then
            floatBodyPosition:Destroy(); floatBodyPosition = nil
            local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z) end
        end
        if mainGUI then refreshMainGUI() end
    elseif KEYBINDS.TPDOWN == keyName then
        tpDownAction()
    elseif KEYBINDS.CARRY == keyName then
        SETTINGS.CARRY_MODE = not SETTINGS.CARRY_MODE
        if mainGUI then refreshMainGUI() end
    end
end)

